{
  "name": "MQTT C Lab",
  "image": "mcr.microsoft.com/devcontainers/cpp:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/apt-packages:1": {
      "packages": "libmosquitto-dev,mosquitto-clients,mosquitto"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools"
      ]
    }
  },
  "remoteUser": "vscode"
}
